# Copy to .env and fill in real values; .env is git-ignored.
# All keys map 1:1 to fields in config.Settings (case-insensitive).

# ── LLM ──────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-***
ANTHROPIC_API_KEY=sk-ant-***
EMBEDDING_MODEL=text-embedding-3-small

# ── GitHub search (optional; bound to Technical Support when TECH_SUPPORT_GITHUB_REPOS is set) ──
# Unauthenticated requests are accepted but rate-limited to 10 req/min; token recommended.
GITHUB_API_TOKEN=ghp_***
# CSV of owner/repo strings. Full GitHub URLs are normalized to owner/repo automatically.
TECH_SUPPORT_GITHUB_REPOS=ProzorroUKR/prozorro-pdf,ProzorroUKR/prozorro-eds

# ── Web search (Tavily) ──────────────────────────────────────────────
TAVILY_API_KEY=tvly-***
# CSV of bare hostnames — host-only values are canonical (e.g. "docs.prozorro.org").
# Full URLs are normalized to hostnames automatically. GitHub repos belong in
# TECH_SUPPORT_GITHUB_REPOS, not here.
TECH_SUPPORT_ALLOWED_DOMAINS=docs.prozorro.org,infobox.prozorro.org
TECH_SUPPORT_TAG_WHITELIST=tutorial,interface,marketplace

# ── Vector DB (Qdrant) ───────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_LAWS_COLLECTION=laws
QDRANT_ARTICLES_COLLECTION=articles
LAWS_FRESHNESS_THRESHOLD_DAYS=180
ARTICLES_FRESHNESS_THRESHOLD_DAYS=365

# ── Hybrid retrieval ─────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
HYBRID_SEMANTIC_WEIGHT=0.6
HYBRID_BM25_WEIGHT=0.4

# ── Reranking ────────────────────────────────────────────────────────
RERANKER_MODEL=BAAI/bge-reranker-base
RERANK_TOP_K=5
RERANK_SCORE_THRESHOLD=0.3

# ── Postgres (LangGraph checkpointer) ────────────────────────────────
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/agent_sessions
SESSION_TTL_HOURS=24

# ── Slack ────────────────────────────────────────────────────────────
SLACK_APP_TOKEN=xapp-1-...
SLACK_BOT_TOKEN=xoxb-***
SLACK_SIGNING_SECRET=***
SLACK_USER_CHANNEL_ID=C0000000000
SLACK_EXPERT_CHANNEL_ID=C0000000000

# ── Confluence (optional; bound to Technical Support when set) ───────
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_USERNAME=your-email@example.com
CONFLUENCE_API_TOKEN=***
# CSV — parsed via field_validator into list[str]. Leave empty to search all spaces.
#CONFLUENCE_SPACE_KEYS=Knowledge,PROZORRO

# ── Agent behavior ───────────────────────────────────────────────────
CRITIC_MAX_RETRIES=3
# Approve after the first revision if avg(freshness, completeness, structure) >= this
CRITIC_MIN_APPROVE_SCORE=0.5
WORKER_TIMEOUT_SECONDS=60
PLANNER_MAX_SUBTASKS=3

# ── Observability (Langfuse) ─────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-***
LANGFUSE_SECRET_KEY=sk-lf-***
LANGFUSE_BASE_URL=https://cloud.langfuse.com
